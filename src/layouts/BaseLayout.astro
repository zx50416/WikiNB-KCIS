---
import '../styles/global.css';
import Header from '../components/Header.astro';
import DecorBackground from '../components/DecorBackground.astro';
import sites from '../../config/sites.json';

interface Props {
  title: string;
  description?: string;
}

const { title, description = sites.brand.tagline } = Astro.props;
const brand = sites.brand.name;
const fullTitle =
  title === brand || title === 'WikiNB' || title === sites.brand.shortName
    ? title === 'WikiNB' || title === sites.brand.shortName
      ? 'WikiNB · KCIS'
      : title
    : `${title} · WikiNB KCIS`;

const authJson = JSON.stringify({
  url:
    import.meta.env.PUBLIC_AUTH_URL ||
    sites.auth?.url ||
    'http://127.0.0.1:8788',
  productionUrl:
    import.meta.env.PUBLIC_AUTH_PRODUCTION_URL ||
    sites.auth?.productionUrl ||
    '',
  allowedEmailDomain: sites.auth?.allowedEmailDomain || 'kcis.com.tw',
});
---

<!doctype html>
<html lang="zh-Hant" data-base={import.meta.env.BASE_URL}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}brand/kangchiao-logo.png`} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
      crossorigin="anonymous"
    />
    <title>{fullTitle}</title>
    <script id="auth-config" type="application/json" set:html={authJson}></script>
  </head>
  <body>
    <div class="kc-shell">
      <DecorBackground />
      <Header />
      <main class="mx-auto max-w-6xl px-4 pb-16 pt-24 md:px-8">
        <slot />
      </main>
    </div>
  </body>
</html>
