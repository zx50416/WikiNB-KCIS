---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Set display name" description="Set your display name to finish sign-in">
  <div class="animate-fadeIn mx-auto max-w-md">
    <div class="kc-hero relative overflow-hidden rounded-[1.75rem] border px-6 py-10 sm:px-8">
      <div class="kc-hero-glow" aria-hidden="true"></div>
      <div class="relative z-[1]">
        <h1 id="setup-title" class="text-center font-display text-3xl font-bold text-kc-blue-deep">
          Set display name
        </h1>
        <p id="setup-subtitle" class="mt-2 text-center text-sm text-kc-muted">
          Code confirmed. Set a display name to enter the system.
        </p>

        <p id="setup-error" class="mt-4 hidden text-center text-sm text-red-600" role="alert"></p>
        <p id="setup-ok" class="mt-4 hidden text-center text-sm text-emerald-700"></p>

        <div id="setup-panel" class="mt-6 hidden space-y-3">
          <p class="text-sm text-kc-muted">
            Account: <strong id="label-email" class="text-kc-blue-deep"></strong>
          </p>

          <div id="nickname-block" class="space-y-3">
            <label class="block text-sm font-semibold text-kc-blue-deep" data-i18n="login.nicknameLabel"
              >Display name (required)</label
            >
            <input
              id="input-nickname"
              type="text"
              class="search-input pl-5"
              autocomplete="nickname"
              maxlength="20"
              placeholder=""
            />
            <p class="text-xs text-kc-muted" data-i18n="login.nicknameHint">
              Only Chinese, English letters, ( _  . ) are allowed; length 2–20 characters.
            </p>
          </div>

          <button
            id="btn-finish"
            type="button"
            class="kc-btn-primary w-full justify-center py-3"
            data-i18n="login.finish"
          >
            Finish &amp; sign in
          </button>
          <a
            id="link-back"
            href={`${base}login`}
            class="block w-full text-center text-sm font-semibold text-kc-blue hover:text-kc-purple"
            data-i18n="login.back"
          >
            ← Back to login
          </a>
        </div>

        <div id="setup-missing" class="mt-6 hidden text-center text-sm text-kc-muted">
          <p>Verification expired or incomplete. Please sign in again.</p>
          <a href={`${base}login`} class="mt-3 inline-block font-semibold text-kc-blue underline" data-i18n="login.back"
            >← Back to login</a
          >
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import {
    clearSetupSession,
    completeSetup,
    readSetupSession,
  } from '../../scripts/auth-client.js';

  function pageBase() {
    return document.documentElement.dataset.base || '/WikiNB-KCIS/';
  }

  const errEl = document.getElementById('setup-error');
  const okEl = document.getElementById('setup-ok');
  const panel = document.getElementById('setup-panel');
  const missing = document.getElementById('setup-missing');

  const session = readSetupSession();
  if (!session) {
    missing?.classList.remove('hidden');
  } else {
    panel?.classList.remove('hidden');
    const label = document.getElementById('label-email');
    if (label) label.textContent = session.email;
    const nick = document.getElementById('input-nickname');
    if (nick) {
      nick.focus();
    }
  }

  function showErr(msg) {
    if (!errEl) return;
    errEl.textContent = msg || '';
    errEl.classList.toggle('hidden', !msg);
  }
  function showOk(msg) {
    if (!okEl) return;
    okEl.textContent = msg || '';
    okEl.classList.toggle('hidden', !msg);
  }

  document.getElementById('btn-finish')?.addEventListener('click', async () => {
    showErr('');
    showOk('');
    const data = readSetupSession();
    if (!data) {
      panel?.classList.add('hidden');
      missing?.classList.remove('hidden');
      return;
    }

    const nickname = document.getElementById('input-nickname')?.value?.trim() || '';
    if (!nickname) {
      showErr('Please enter a display name');
      document.getElementById('input-nickname')?.focus();
      return;
    }

    const btn = document.getElementById('btn-finish');
    try {
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = 'Saving…';
      }
      const result = await completeSetup({
        email: data.email,
        code: data.code,
        nickname,
        purpose: data.purpose || 'login',
      });
      clearSetupSession();
      showOk(result.message || 'Saved');
      window.location.href = `${pageBase()}login/success`;
    } catch (err) {
      showErr(err.message || 'Could not finish setup');
    } finally {
      if (btn) {
        btn.removeAttribute('disabled');
        btn.textContent = 'Finish & sign in';
      }
    }
  });

  document.getElementById('link-back')?.addEventListener('click', () => {
    clearSetupSession();
  });

  document.getElementById('input-nickname')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('btn-finish')?.click();
  });
</script>
