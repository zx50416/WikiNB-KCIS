---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Signed in" description="You are signed in to WikiNB KCIS">
  <div class="animate-fadeIn mx-auto max-w-lg">
    <div class="kc-hero relative overflow-hidden rounded-[1.75rem] border px-6 py-12 text-center sm:px-10">
      <div class="kc-hero-glow" aria-hidden="true"></div>
      <div class="relative z-[1]">
        <p class="text-sm font-semibold tracking-wide text-kc-purple">WikiNB · KCIS</p>
        <h1 id="hello-title" class="mt-3 cursor-pointer font-display text-3xl font-bold text-kc-blue-deep sm:text-4xl">
          Hello!
        </h1>
        <p id="hello-sub" class="mt-3 text-sm text-kc-muted">Checking sign-in…</p>

        <div id="user-card" class="mx-auto mt-8 hidden max-w-sm rounded-2xl border border-white/70 bg-white/70 p-5 text-left">
          <p class="text-xs font-semibold uppercase tracking-wide text-kc-muted">Account</p>
          <p id="user-email" class="mt-1 break-all text-sm text-kc-blue-deep"></p>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-kc-muted">Role</p>
          <p id="user-role" class="mt-1 text-sm text-kc-blue-deep"></p>
        </div>

        <div id="actions" class="mt-8 hidden flex flex-wrap items-center justify-center gap-3">
          <a id="link-codex" href={`${base}codex`} class="success-btn-gemini"
            ><span class="success-btn-gemini-label" data-i18n="nav.gemini">Gemini × KCIS</span></a
          >
          <a id="link-notes" href={`${base}notes`} class="success-btn-gemini success-btn-addnote" hidden aria-hidden="true"
            ><span class="success-btn-gemini-label" data-i18n="home.addNote">+ Add note</span></a
          >
        </div>

        <p id="success-error" class="mt-6 hidden text-sm text-red-600"></p>
        <p class="mt-6 text-center text-sm text-kc-muted">
          Not signed in?
          <a href={`${base}login`} class="font-semibold text-kc-blue underline" data-i18n="login.back">← Back to login</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .success-btn-gemini {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    min-width: 9.5rem;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid transparent;
    padding: 0.7rem 1.4rem;
    font-family: inherit;
    font-weight: 800;
    text-decoration: none;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(120deg, #4285f4, #9b72cb, #d96570, #fbbc05, #34a853, #4285f4) border-box;
    box-shadow: 0 8px 22px rgba(66, 133, 244, 0.12);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  /* 新增筆記預設隱藏；避免 display:inline-flex 蓋掉 .hidden */
  .success-btn-addnote {
    display: none;
  }

  .success-btn-addnote.is-teacher-visible {
    display: inline-flex;
  }

  .success-btn-gemini::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      rgba(66, 133, 244, 0.08),
      rgba(155, 114, 203, 0.1),
      rgba(217, 101, 112, 0.08),
      rgba(251, 188, 5, 0.08),
      rgba(52, 168, 83, 0.08)
    );
    opacity: 0.85;
  }

  .success-btn-gemini-label {
    position: relative;
    z-index: 2;
    letter-spacing: 0.02em;
    background: linear-gradient(105deg, #1a73e8 0%, #7b61ff 45%, #d96570 75%, #0f9d9a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .success-btn-gemini:hover,
  .success-btn-gemini:focus-visible {
    transform: translateY(-1px) scale(1.02);
    box-shadow: 0 12px 28px rgba(123, 97, 255, 0.2);
    outline: none;
  }
</style>

<script>
  import { displayUserName, fetchMe, isTeacherUser } from '../../scripts/auth-client.js';

  const title = document.getElementById('hello-title');
  const sub = document.getElementById('hello-sub');
  const card = document.getElementById('user-card');
  const actions = document.getElementById('actions');
  const errEl = document.getElementById('success-error');

  function roleLabel(role) {
    if (role === 'admin') return 'Admin';
    if (role === 'teacher') return 'Teacher';
    return 'Student';
  }

  function pageBase() {
    return document.documentElement.dataset.base || '/WikiNB-KCIS/';
  }

  function render(user) {
    const name = displayUserName(user);
    if (title) title.textContent = `Hello! ${name}`;
    if (sub) sub.textContent = 'Signed in. You can start using WikiNB KCIS.';
    card?.classList.remove('hidden');
    actions?.classList.remove('hidden');
    const emailEl = document.getElementById('user-email');
    const roleEl = document.getElementById('user-role');
    if (emailEl) emailEl.textContent = user.email;
    if (roleEl) roleEl.textContent = roleLabel(user.role);
    const teacher = isTeacherUser(user) || user.role === 'admin';
    const notesLink = document.getElementById('link-notes');
    if (notesLink) {
      notesLink.classList.toggle('is-teacher-visible', teacher);
      notesLink.toggleAttribute('hidden', !teacher);
      notesLink.setAttribute('aria-hidden', teacher ? 'false' : 'true');
    }
  }

  (async () => {
    try {
      const me = await fetchMe();
      if (!me.authenticated || !me.user) {
        if (errEl) {
          errEl.textContent = 'Not signed in or session expired';
          errEl.classList.remove('hidden');
        }
        if (sub) sub.textContent = 'Please complete email code sign-in first.';
        return;
      }
      render(me.user);
    } catch (err) {
      if (errEl) {
        errEl.textContent = err.message || 'Could not confirm sign-in';
        errEl.classList.remove('hidden');
      }
    }
  })();

  document.getElementById('hello-title')?.addEventListener('click', () => {
    window.location.href = `${pageBase()}nickname`;
  });
</script>
