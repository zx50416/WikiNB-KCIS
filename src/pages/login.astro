---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="登入" description="Email 驗證碼登入 WikiNB KCIS">
  <div class="animate-fadeIn mx-auto max-w-md">
    <div class="kc-hero relative overflow-hidden rounded-[1.75rem] border px-6 py-10 sm:px-8">
      <div class="kc-hero-glow" aria-hidden="true"></div>
      <div class="relative z-[1]">
        <h1 class="text-center font-display text-3xl font-bold text-kc-blue-deep">登入</h1>
        <p class="mt-2 text-center text-sm text-kc-muted" data-i18n="login.subtitle">
          僅限 @kcis.com.tw 與核准測試信箱
        </p>

        <div
          id="login-offline"
          class="mt-5 hidden rounded-2xl border border-amber-200 bg-amber-50/80 p-4 text-left text-sm leading-relaxed text-amber-950"
        ></div>
        <div id="login-local-hint" class="mt-3 hidden space-y-3 rounded-2xl border border-kc-blue/20 bg-white/70 p-4 text-left text-sm text-kc-blue-deep">
          <p id="hint-title" class="font-semibold"></p>
          <p id="hint-body" class="text-xs text-kc-muted"></p>
          <p id="hint-note" class="text-xs text-kc-muted"></p>
          <div id="hint-commands" class="space-y-3"></div>
          <p id="hint-refresh" class="hidden rounded-lg bg-kc-mist/80 px-3 py-2 text-xs font-semibold text-kc-blue-deep"></p>
        </div>
        <p id="login-error" class="mt-4 hidden text-center text-sm text-red-600" role="alert"></p>
        <p id="login-ok" class="mt-4 hidden text-center text-sm text-emerald-700"></p>
        <p id="login-status" class="mt-2 text-center text-sm text-kc-muted"></p>

        <div id="panel-email" class="mt-6 space-y-3">
          <label class="block text-sm font-semibold text-kc-blue-deep">Email</label>
          <input
            id="input-email"
            type="email"
            class="search-input pl-5"
            autocomplete="username"
            placeholder="you@kcis.com.tw"
          />
          <button id="btn-continue" type="button" class="kc-btn-primary w-full justify-center py-3">
            寄送驗證碼
          </button>
        </div>

        <div id="panel-code" class="mt-6 hidden space-y-3">
          <p class="text-sm text-kc-muted">
            帳號：<strong id="label-email-code" class="text-kc-blue-deep"></strong>
          </p>
          <label class="block text-sm font-semibold text-kc-blue-deep">六位數驗證碼</label>
          <input
            id="input-code"
            type="text"
            inputmode="numeric"
            maxlength="6"
            class="search-input pl-5 text-center tracking-[0.3em]"
            placeholder="000000"
          />
          <button id="btn-verify-code" type="button" class="kc-btn-primary w-full justify-center py-3">
            確認驗證碼並登入
          </button>
          <button id="btn-resend" type="button" class="kc-btn-ghost w-full justify-center">
            重新寄送驗證碼
          </button>
          <button id="btn-back" type="button" class="w-full text-center text-sm font-semibold text-kc-blue hover:text-kc-purple">
            ← 更換 Email
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import {
    CODE_SENT_HINT,
    REFRESH_AFTER_HOST_HINT,
    diagnoseAuthConnection,
    fetchMe,
    lookupEmail,
    loginWithCode,
    logout,
    saveSetupSession,
    sendAuthCode,
    verifyAuthCode,
  } from '../scripts/auth-client.js';

  function pageBase() {
    return document.documentElement.dataset.base || '/WikiNB-KCIS/';
  }

  const offlineEl = document.getElementById('login-offline');
  const localHintEl = document.getElementById('login-local-hint');
  const hintTitle = document.getElementById('hint-title');
  const hintBody = document.getElementById('hint-body');
  const hintNote = document.getElementById('hint-note');
  const hintRefresh = document.getElementById('hint-refresh');
  const hintCommands = document.getElementById('hint-commands');
  const errEl = document.getElementById('login-error');
  const okEl = document.getElementById('login-ok');
  const statusEl = document.getElementById('login-status');
  const panelEmail = document.getElementById('panel-email');
  const panelCode = document.getElementById('panel-code');

  let currentEmail = '';
  let currentRole = 'student';

  function codeSentHint(result) {
    if (result?.fallback || result?.dev) {
      return (
        result.message ||
        '驗證碼已顯示於 Auth 終端機（跑 npm run auth 的那個視窗），請到終端機查看六位數。'
      );
    }
    return result?.message || CODE_SENT_HINT;
  }

  function showErr(msg) {
    if (!errEl) return;
    errEl.textContent = msg || '';
    errEl.classList.toggle('hidden', !msg);
  }
  function showOk(msg) {
    if (!okEl) return;
    okEl.textContent = msg || '';
    okEl.classList.toggle('hidden', !msg);
  }
  function showStatus(msg) {
    if (!statusEl) return;
    statusEl.textContent = msg || '';
  }

  async function copyText(text, btn) {
    try {
      await navigator.clipboard.writeText(text);
      if (btn) {
        const prev = btn.textContent;
        btn.textContent = '已複製！去終端機貼上';
        setTimeout(() => {
          btn.textContent = prev;
        }, 2000);
      }
    } catch {
      if (btn) btn.textContent = '請手動全選上方指令';
    }
  }

  function renderHostHint(diag) {
    if (!localHintEl || !hintCommands) return;
    if (hintTitle) hintTitle.textContent = diag.title || '請在終端機操作';
    if (hintBody) hintBody.textContent = diag.message || '';
    if (hintNote) hintNote.textContent = diag.hint || '';
    if (hintRefresh) {
      hintRefresh.textContent = REFRESH_AFTER_HOST_HINT;
      hintRefresh.classList.remove('hidden');
    }
    hintCommands.innerHTML = '';
    for (const item of diag.commands || []) {
      const wrap = document.createElement('div');
      wrap.className = 'space-y-1.5';
      const lab = document.createElement('p');
      lab.className = 'text-xs font-semibold text-kc-blue-deep';
      lab.textContent = item.label;
      const pre = document.createElement('pre');
      pre.className =
        'overflow-x-auto rounded-xl bg-kc-blue-deep/95 p-3 text-left text-[11px] leading-relaxed text-white whitespace-pre-wrap break-all';
      pre.textContent = item.cmd;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'kc-btn-secondary w-full justify-center py-2 text-sm';
      btn.textContent = '複製這段';
      btn.addEventListener('click', () => copyText(item.cmd, btn));
      wrap.appendChild(lab);
      wrap.appendChild(pre);
      wrap.appendChild(btn);
      hintCommands.appendChild(wrap);
    }
    localHintEl.classList.remove('hidden');
  }

  function showEmailStep() {
    panelEmail?.classList.remove('hidden');
    panelCode?.classList.add('hidden');
    currentEmail = '';
  }

  function showCodeStep(email, _hint, role = 'student') {
    panelEmail?.classList.add('hidden');
    panelCode?.classList.remove('hidden');
    currentEmail = email;
    currentRole = role;
    const label = document.getElementById('label-email-code');
    if (label) label.textContent = email;
    const codeInput = document.getElementById('input-code');
    if (codeInput) codeInput.value = '';
  }

  diagnoseAuthConnection().then((diag) => {
    if (diag.online) return;
    if (offlineEl) {
      offlineEl.textContent = diag.title || diag.message || 'Auth 未連線';
      offlineEl.classList.remove('hidden');
    }
    renderHostHint(diag);
    if (diag.reason === 'local-auth-offline') {
      panelEmail?.classList.add('hidden');
    }
  });

  (async () => {
    const params = new URLSearchParams(window.location.search);
    if (params.get('logged_out')) {
      await logout();
      showEmailStep();
      window.history.replaceState({}, '', window.location.pathname);
      return;
    }
    try {
      const me = await fetchMe();
      if (me.authenticated && me.user) {
        window.location.href = `${pageBase()}login/success`;
      }
    } catch {
      /* ignore */
    }
  })();

  document.getElementById('btn-continue')?.addEventListener('click', async () => {
    showErr('');
    showOk('');
    showStatus('');
    const email = document.getElementById('input-email')?.value?.trim();
    if (!email) {
      showErr('請輸入 Email');
      document.getElementById('input-email')?.focus();
      return;
    }
    const btn = document.getElementById('btn-continue');
    try {
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = '寄送中…';
      }
      showStatus('正在寄送驗證碼，請稍候…');
      const result = await lookupEmail(email);
      showStatus('');
      showOk(codeSentHint(result));
      showCodeStep(result.email, codeSentHint(result), result.role || 'student');
    } catch (err) {
      showStatus('');
      showErr(err.message || 'Email 無效或寄信失敗');
    } finally {
      if (btn) {
        btn.removeAttribute('disabled');
        btn.textContent = '寄送驗證碼';
      }
    }
  });

  document.getElementById('input-email')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('btn-continue')?.click();
  });

  document.getElementById('btn-resend')?.addEventListener('click', async () => {
    showErr('');
    showOk('');
    const btn = document.getElementById('btn-resend');
    try {
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = '寄送中…';
      }
      const result = await sendAuthCode(currentEmail, 'login');
      showOk(codeSentHint(result));
    } catch (err) {
      showErr(err.message || '寄送失敗');
    } finally {
      if (btn) {
        btn.removeAttribute('disabled');
        btn.textContent = '重新寄送驗證碼';
      }
    }
  });

  document.getElementById('btn-verify-code')?.addEventListener('click', async () => {
    showErr('');
    showOk('');
    const code = document.getElementById('input-code')?.value?.trim();
    const btn = document.getElementById('btn-verify-code');
    try {
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = '驗證中…';
      }
      const checked = await verifyAuthCode(currentEmail, code, 'login');
      if (checked.needsNickname || checked.next === 'setup') {
        saveSetupSession({
          email: currentEmail,
          code,
          purpose: 'login',
          role: checked.role || currentRole,
        });
        window.location.href = `${pageBase()}login/setup`;
        return;
      }
      const result = await loginWithCode({ email: currentEmail, code, purpose: 'login' });
      showOk(result.message || '登入成功');
      window.location.href = `${pageBase()}login/success`;
    } catch (err) {
      showErr(err.message || '驗證碼錯誤');
    } finally {
      if (btn) {
        btn.removeAttribute('disabled');
        btn.textContent = '確認驗證碼並登入';
      }
    }
  });

  document.getElementById('input-code')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('btn-verify-code')?.click();
  });

  document.getElementById('btn-back')?.addEventListener('click', () => {
    showErr('');
    showOk('');
    showEmailStep();
  });
</script>
