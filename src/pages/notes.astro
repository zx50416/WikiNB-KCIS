---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Add note" description="Modify, add, or write a teaching note online">
  <div class="animate-fadeIn mx-auto max-w-5xl">
    <div class="mb-8">
      <h1 class="font-display text-3xl font-bold text-kc-blue-deep md:text-4xl" data-i18n="notes.title">Add note</h1>
      <p class="mt-2 text-sm text-kc-muted md:text-base" data-i18n="notes.subtitle">Choose how to start</p>
    </div>

    <div id="notes-gate" class="kc-card hidden p-8 text-center">
      <p class="text-kc-muted" data-i18n="editor.gate">Please sign in with a teacher account.</p>
    </div>

    <div id="notes-panel" class="hidden space-y-4">
      <div class="grid items-stretch gap-4 md:grid-cols-3">
        <a href={`${base}my-notes`} class="notes-card">
          <span class="notes-card-title" data-i18n="notes.modify">Modify</span>
          <span class="notes-card-hint" data-i18n="notes.modifyHint">View, edit, or delete your existing notes</span>
        </a>

        <a href={`${base}editor?mode=upload`} class="notes-card">
          <span class="notes-card-title" data-i18n="notes.add">Add (upload .md)</span>
          <span class="notes-card-hint" data-i18n="notes.addHint">Import an existing Markdown file</span>
        </a>

        <a href={`${base}editor?mode=new`} class="notes-card">
          <span class="notes-card-title" data-i18n="notes.online">Online editor</span>
          <span class="notes-card-hint" data-i18n="notes.onlineHint">Write a new note from scratch</span>
        </a>
      </div>

      <div class="kc-card space-y-3 p-4 text-left sm:p-5">
        <button
          id="btn-kuse-toggle"
          type="button"
          class="flex w-full items-center justify-between gap-2 rounded-xl border border-kc-purple/25 bg-gradient-to-r from-white to-kc-mist/40 px-4 py-3 text-sm font-bold text-kc-blue-deep transition hover:border-kc-purple/50 sm:text-base"
          aria-expanded="false"
        >
          <span data-i18n="kuse.how">如何讓 AI 生成 .md？</span>
          <span id="kuse-caret" aria-hidden="true">▾</span>
        </button>
        <div id="kuse-panel" class="hidden space-y-4 border-t border-[color:var(--kc-line)] pt-4">
          <p class="text-sm text-kc-muted" data-i18n="kuse.help">
            Paste your rough notes below, copy the prompt, open the AI tool, ask it for a clean Markdown file, then
            upload here.
          </p>
          <label class="block text-sm font-semibold text-kc-blue-deep">
            <span data-i18n="kuse.notesLabel">Your notes (paste here)</span>
            <textarea
              id="kuse-notes"
              class="search-input mt-2 min-h-[14rem] py-3 text-sm sm:min-h-[18rem] sm:text-base"
              placeholder="Paste your teaching notes…"
            ></textarea>
          </label>
          <div class="grid grid-cols-2 gap-3">
            <button id="btn-kuse-copy" type="button" class="kc-btn-primary w-full justify-center py-3 text-sm" data-i18n="kuse.copy"
              >Copy prompt</button
            >
            <a
              id="link-kuse"
              href="https://kuse.knsh.com.tw/"
              target="_blank"
              rel="noopener noreferrer"
              class="kc-btn-secondary w-full justify-center py-3 text-sm"
              data-i18n="kuse.open"
              >Open Kuse</a
            >
          </div>
          <p id="kuse-copy-status" class="text-xs text-kc-muted"></p>
        </div>
      </div>
    </div>

    <p class="mt-8 flex flex-wrap gap-4">
      <a href={`${base}my-notes`} class="text-sm font-semibold text-kc-blue hover:text-kc-purple" data-i18n="home.myNotes"
        >My notes</a
      >
      <a href={base} class="text-sm font-semibold text-kc-blue hover:text-kc-purple" data-i18n="notes.back">← Main</a>
    </p>
  </div>
</BaseLayout>

<style>
  .notes-card {
    display: flex;
    min-height: 9.5rem;
    flex-direction: column;
    justify-content: center;
    gap: 0.45rem;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--kc-line) 80%, white);
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(240, 246, 255, 0.88));
    padding: 1.25rem 1.1rem;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(27, 79, 156, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .notes-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--kc-purple) 40%, white);
    box-shadow: 0 16px 34px rgba(107, 61, 154, 0.14);
  }

  .notes-card-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--kc-blue-deep);
  }

  .notes-card-hint {
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--kc-muted);
  }
</style>

<script>
  import { fetchMe, isTeacherUser } from '../scripts/auth-client.js';

  (async () => {
    const me = await fetchMe().catch(() => ({ authenticated: false }));
    const ok = me.authenticated && isTeacherUser(me.user);
    document.getElementById('notes-gate')?.classList.toggle('hidden', ok);
    document.getElementById('notes-panel')?.classList.toggle('hidden', !ok);
  })();

  function buildKusePrompt(notes) {
    const body = String(notes || '').trim() || '{pasted notes}';
    return [
      '請幫我把下面的教學筆記整理成一份美觀、結構清楚的 Markdown（.md）檔案。',
      '請使用適當的標題、條列、粗體，並保留重點；不要加入與內容無關的說明。',
      '完成後請輸出完整的 Markdown 內容，方便我下載或複製後上傳到 WikiNB。',
      '',
      '（老師的筆記）',
      '',
      body,
    ].join('\n');
  }

  const toggle = document.getElementById('btn-kuse-toggle');
  toggle?.addEventListener('click', () => {
    const panel = document.getElementById('kuse-panel');
    const hidden = panel?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!hidden));
    const caret = document.getElementById('kuse-caret');
    if (caret) caret.textContent = hidden ? '▾' : '▴';
  });

  document.getElementById('btn-kuse-copy')?.addEventListener('click', async () => {
    const notes = document.getElementById('kuse-notes')?.value || '';
    const prompt = buildKusePrompt(notes);
    const status = document.getElementById('kuse-copy-status');
    try {
      await navigator.clipboard.writeText(prompt);
      if (status) status.textContent = 'Copied. Open Kuse and paste the prompt.';
    } catch {
      if (status) status.textContent = 'Copy failed — select and copy manually.';
    }
  });
</script>
