---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="My notes" description="View, edit, or delete your teaching notes">
  <div class="animate-fadeIn mx-auto max-w-4xl">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="font-display text-3xl font-bold text-kc-blue-deep md:text-4xl" data-i18n="home.myNotes">My notes</h1>
        <p class="mt-2 text-sm text-kc-muted" data-i18n="myNotes.subtitle">View, edit, or delete notes in your folder</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href={`${base}notes`} class="home-btn-gemini justify-center py-2 text-sm"
          ><span class="home-btn-gemini-label" data-i18n="home.addNote">+ Add note</span></a
        >
        <a href={base} class="kc-btn-ghost shrink-0 text-sm" data-i18n="notes.back">← Main</a>
      </div>
    </div>

    <div id="mynotes-gate" class="kc-card hidden p-8 text-center">
      <p class="text-kc-muted" data-i18n="editor.gate">Please sign in with a teacher account.</p>
    </div>

    <div id="mynotes-offline" class="kc-card hidden border border-amber-200 bg-amber-50/50 p-6 text-center text-amber-900"></div>

    <div id="mynotes-loading" class="kc-card hidden space-y-2 border border-kc-blue/20 bg-white/80 p-6 text-left">
      <p class="text-sm font-semibold text-kc-blue-deep" data-i18n="myNotes.loadingTitle">Loading your notes…</p>
      <p class="text-sm text-kc-muted" data-i18n="myNotes.loadingHint">
        This can take up to about a minute when syncing with cloud storage. Please wait.
      </p>
      <p id="mynotes-elapsed" class="font-mono text-lg font-bold text-kc-blue-deep">0s</p>
    </div>

    <div id="mynotes-panel" class="hidden space-y-4">
      <p id="mynotes-status" class="text-sm text-kc-muted"></p>
      <div id="mynotes-list" class="space-y-3"></div>
      <p id="mynotes-empty" class="kc-card hidden p-8 text-center text-kc-muted" data-i18n="myNotes.empty">
        No notes yet in your teacher folder. Add one from + Add note.
      </p>
      <p id="mynotes-folder" class="text-xs text-kc-muted"></p>
    </div>
  </div>

  <div
    id="mynotes-del-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-kc-blue-deep/45 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mynotes-del-title"
  >
    <div class="w-full max-w-md rounded-2xl border border-white/70 bg-white p-6 shadow-xl">
      <h2 id="mynotes-del-title" class="font-display text-xl font-bold text-kc-blue-deep" data-i18n="myNotes.deleteTitle">
        Delete this note?
      </h2>
      <p id="mynotes-del-body" class="mt-2 text-sm text-kc-muted"></p>
      <p class="mt-3 text-xs text-kc-muted" data-i18n="myNotes.deleteWaitHint">
        To avoid accidents, wait 3 seconds before you can confirm.
      </p>
      <p id="mynotes-del-countdown" class="mt-2 font-mono text-lg font-bold text-kc-blue-deep">3s</p>
      <div class="mt-5 flex flex-wrap justify-end gap-2">
        <button id="mynotes-del-cancel" type="button" class="kc-btn-ghost py-2 text-sm" data-i18n="myNotes.deleteCancel"
          >Cancel</button
        >
        <button
          id="mynotes-del-confirm"
          type="button"
          class="rounded-full bg-red-600 px-4 py-2 text-sm font-bold text-white opacity-50 disabled:cursor-not-allowed"
          disabled
          data-i18n="myNotes.deleteConfirm"
          >Delete</button
        >
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-btn-gemini {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid transparent;
    padding: 0.55rem 1.2rem;
    font-family: inherit;
    font-weight: 700;
    text-decoration: none;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(120deg, #4285f4, #9b72cb, #d96570, #fbbc05, #34a853, #4285f4) border-box;
    box-shadow: 0 8px 22px rgba(66, 133, 244, 0.12);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .home-btn-gemini-label {
    position: relative;
    z-index: 2;
    letter-spacing: 0.02em;
    background: linear-gradient(105deg, #1a73e8 0%, #7b61ff 45%, #d96570 75%, #0f9d9a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .home-btn-gemini::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      rgba(66, 133, 244, 0.08),
      rgba(155, 114, 203, 0.1),
      rgba(217, 101, 112, 0.08),
      rgba(251, 188, 5, 0.08),
      rgba(52, 168, 83, 0.08)
    );
    opacity: 0.85;
  }

  .home-btn-gemini:hover,
  .home-btn-gemini:focus-visible {
    transform: translateY(-1px) scale(1.015);
    box-shadow: 0 12px 28px rgba(123, 97, 255, 0.2);
    outline: none;
  }
</style>

<script>
  import {
    checkAuthHealth,
    deleteWikiNote,
    fetchMe,
    isTeacherUser,
    listAllWikiFiles,
  } from '../scripts/auth-client.js';
  import { t } from '../scripts/i18n.js';

  function pageBase() {
    return document.documentElement.dataset.base || '/WikiNB-KCIS/';
  }

  const gate = document.getElementById('mynotes-gate');
  const offline = document.getElementById('mynotes-offline');
  const loadingEl = document.getElementById('mynotes-loading');
  const elapsedEl = document.getElementById('mynotes-elapsed');
  const panel = document.getElementById('mynotes-panel');
  const listEl = document.getElementById('mynotes-list');
  const emptyEl = document.getElementById('mynotes-empty');
  const statusEl = document.getElementById('mynotes-status');

  let elapsedTimer = null;

  function startElapsed() {
    const t0 = Date.now();
    loadingEl?.classList.remove('hidden');
    if (elapsedEl) elapsedEl.textContent = '0s';
    clearInterval(elapsedTimer);
    elapsedTimer = setInterval(() => {
      const sec = Math.floor((Date.now() - t0) / 1000);
      if (elapsedEl) elapsedEl.textContent = `${sec}s`;
      if (sec >= 15 && statusEl) {
        statusEl.textContent = t('myNotes.loadingSlow');
      }
    }, 1000);
  }

  function stopElapsed() {
    clearInterval(elapsedTimer);
    elapsedTimer = null;
    loadingEl?.classList.add('hidden');
  }

  function setStatus(text, isError = false) {
    if (!statusEl) return;
    statusEl.textContent = text || '';
    statusEl.classList.toggle('text-red-600', isError);
    statusEl.classList.toggle('text-kc-muted', !isError);
  }

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  let currentTeacherId = '';
  let pendingDelete = null;
  let deleteCountdownTimer = null;

  const delModal = document.getElementById('mynotes-del-modal');
  const delBody = document.getElementById('mynotes-del-body');
  const delCountdown = document.getElementById('mynotes-del-countdown');
  const delCancel = document.getElementById('mynotes-del-cancel');
  const delConfirm = document.getElementById('mynotes-del-confirm');

  function closeDeleteModal() {
    clearInterval(deleteCountdownTimer);
    deleteCountdownTimer = null;
    pendingDelete = null;
    delModal?.classList.add('hidden');
    delModal?.classList.remove('flex');
    if (delConfirm) {
      delConfirm.disabled = true;
      delConfirm.classList.add('opacity-50');
      delConfirm.textContent = t('myNotes.deleteConfirm');
    }
  }

  function openDeleteModal({ subjectId, slug, title }) {
    pendingDelete = { subjectId, slug };
    if (delBody) {
      delBody.textContent = t('myNotes.deleteBody', { name: `${title || slug}.md` });
    }
    delModal?.classList.remove('hidden');
    delModal?.classList.add('flex');
    if (delConfirm) {
      delConfirm.disabled = true;
      delConfirm.classList.add('opacity-50');
      delConfirm.textContent = t('myNotes.deleteConfirm');
    }
    let left = 3;
    if (delCountdown) delCountdown.textContent = `${left}s`;
    clearInterval(deleteCountdownTimer);
    deleteCountdownTimer = setInterval(() => {
      left -= 1;
      if (delCountdown) delCountdown.textContent = `${Math.max(left, 0)}s`;
      if (left <= 0) {
        clearInterval(deleteCountdownTimer);
        deleteCountdownTimer = null;
        if (delConfirm) {
          delConfirm.disabled = false;
          delConfirm.classList.remove('opacity-50');
        }
      }
    }, 1000);
  }

  delCancel?.addEventListener('click', () => closeDeleteModal());
  delModal?.addEventListener('click', (e) => {
    if (e.target === delModal) closeDeleteModal();
  });
  delConfirm?.addEventListener('click', async () => {
    if (!pendingDelete || delConfirm.disabled) return;
    const { subjectId, slug } = pendingDelete;
    try {
      delConfirm.disabled = true;
      delConfirm.textContent = t('myNotes.deleting');
      await deleteWikiNote({ subjectId, slug, teacherId: currentTeacherId });
      closeDeleteModal();
      setStatus(`Deleted ${slug}.md`);
      await loadNotes(currentTeacherId);
    } catch (err) {
      setStatus(err.message || 'Delete failed', true);
      delConfirm.disabled = false;
      delConfirm.textContent = t('myNotes.deleteConfirm');
    }
  });

  async function loadNotes(teacherId) {
    currentTeacherId = teacherId || currentTeacherId;
    startElapsed();
    setStatus(t('myNotes.loadingTitle'));
    try {
      const data = await listAllWikiFiles({ teacherId: currentTeacherId });
      const all = (data.files || []).map((f) => ({
        ...f,
        teacherId: f.teacherId || data.teacherId || currentTeacherId,
        subjectName: f.subjectName || f.subjectId,
      }));
      all.sort((a, b) => String(a.title || a.slug).localeCompare(String(b.title || b.slug), 'zh-Hant'));

      if (!listEl) return;
      if (!all.length) {
        listEl.innerHTML = '';
        emptyEl?.classList.remove('hidden');
        setStatus('');
        return;
      }
      emptyEl?.classList.add('hidden');
      listEl.innerHTML = all
        .map((f) => {
          const viewHref = `${pageBase()}wiki/teachers/${encodeURIComponent(f.teacherId)}/${encodeURIComponent(f.subjectId)}/${encodeURIComponent(f.slug)}`;
          const editHref = `${pageBase()}editor?mode=edit&subjectId=${encodeURIComponent(f.subjectId)}&slug=${encodeURIComponent(f.slug)}`;
          return `<div class="kc-card flex flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between" data-subject="${escapeHtml(f.subjectId)}" data-slug="${escapeHtml(f.slug)}" data-title="${escapeHtml(f.title || f.slug)}">
          <div class="min-w-0 text-left">
            <p class="font-display text-lg font-bold text-kc-blue-deep">${escapeHtml(f.title || f.slug)}</p>
            <p class="mt-1 text-xs text-kc-muted">${escapeHtml(f.subjectName)} · ${escapeHtml(f.slug)}.md</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="kc-btn-ghost py-1.5 text-xs" href="${viewHref}">View</a>
            <a class="kc-btn-secondary py-1.5 text-xs" href="${editHref}">Edit</a>
            <button type="button" class="kc-btn-ghost py-1.5 text-xs text-red-600 my-notes-del">Delete</button>
          </div>
        </div>`;
        })
        .join('');

      listEl.querySelectorAll('.my-notes-del').forEach((btn) => {
        btn.addEventListener('click', () => {
          const row = btn.closest('[data-slug]');
          const subjectId = row?.getAttribute('data-subject');
          const slug = row?.getAttribute('data-slug');
          const title = row?.getAttribute('data-title') || slug;
          if (!subjectId || !slug) return;
          openDeleteModal({ subjectId, slug, title });
        });
      });

      setStatus(
        `${all.length} note(s) · folder wiki/teachers/${data.teacherId || currentTeacherId}/`,
      );
    } catch (err) {
      setStatus(err.message || t('myNotes.loadFailed'), true);
      emptyEl?.classList.remove('hidden');
    } finally {
      stopElapsed();
    }
  }

  (async () => {
    const me = await fetchMe().catch(() => ({ authenticated: false }));
    if (!me.authenticated || !isTeacherUser(me.user)) {
      gate?.classList.remove('hidden');
      return;
    }
    const health = await checkAuthHealth();
    if (!health.online) {
      if (offline) {
        offline.textContent = health.message || 'Auth offline';
        offline.classList.remove('hidden');
      }
      return;
    }
    panel?.classList.remove('hidden');
    const teacherId = me.user.teacherId;
    const folderHint = document.getElementById('mynotes-folder');
    if (folderHint) folderHint.textContent = `Folder: wiki/teachers/${teacherId}/`;
    await loadNotes(teacherId);
  })();
</script>
