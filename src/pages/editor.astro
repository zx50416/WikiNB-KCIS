---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Note editor" description="Teacher note editor — save writes to your Wiki">
  <div class="animate-fadeIn mx-auto max-w-6xl">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="font-display text-3xl font-bold text-kc-blue-deep md:text-4xl" data-i18n="editor.title">
          Note editor
        </h1>
        <p class="mt-2 text-sm text-kc-muted" data-i18n="editor.subtitle">Saving writes to your Wiki</p>
      </div>
      <a href={`${base}my-notes`} class="kc-btn-ghost shrink-0 text-sm" data-i18n="home.myNotes">My notes</a>
    </div>

    <div id="editor-gate" class="kc-card hidden p-8 text-center">
      <p class="text-kc-muted" data-i18n="editor.gate">Please sign in with a teacher account.</p>
    </div>

    <div id="editor-offline" class="kc-card hidden border border-amber-200 bg-amber-50/50 p-6 text-center text-amber-900"></div>

    <div id="editor-panel" class="hidden space-y-4">
      <div id="edit-picker" class="kc-card hidden space-y-3 p-4">
        <label class="block text-sm font-semibold text-kc-blue-deep">
          <span data-i18n="editor.pickNote">Choose a note to edit</span>
          <select id="editor-file" class="search-input mt-1 py-2 text-sm"></select>
        </label>
      </div>

      <div id="upload-zone" class="hidden space-y-4">
        <div class="rounded-2xl border border-dashed border-kc-blue/30 bg-white/60 px-4 py-8 text-center">
          <p class="text-sm font-semibold text-kc-blue-deep" data-i18n="notes.upload">Upload .md</p>
          <label class="kc-btn-secondary mt-4 inline-flex cursor-pointer py-2 text-sm">
            Choose file
            <input id="editor-upload" type="file" accept=".md,.txt,text/markdown,text/plain" class="hidden" />
          </label>
          <p id="upload-drop-hint" class="mt-3 text-xs text-kc-muted">Or drop a .md file here</p>
        </div>

        <div class="kc-card space-y-3 p-4 text-left sm:p-5">
          <button
            id="btn-kuse-toggle"
            type="button"
            class="w-full rounded-xl border border-kc-purple/25 bg-gradient-to-r from-white to-kc-mist/40 px-4 py-3 text-sm font-bold text-kc-blue-deep transition hover:border-kc-purple/50"
            data-i18n="kuse.how"
          >
            How to let AI generate .md?
          </button>
          <div id="kuse-panel" class="hidden space-y-3 border-t border-[color:var(--kc-line)] pt-3">
            <p class="text-sm text-kc-muted" data-i18n="kuse.help">
              Paste your rough notes below, copy the prompt, open 康軒 × Kuse, and ask it to make a clean Markdown file. Then upload the .md here.
            </p>
            <label class="block text-sm font-semibold text-kc-blue-deep">
              <span data-i18n="kuse.notesLabel">Your notes (paste here)</span>
              <textarea
                id="kuse-notes"
                class="search-input mt-1 min-h-[8rem] py-2 text-sm"
                placeholder="Paste your teaching notes…"
              ></textarea>
            </label>
            <div class="flex flex-wrap gap-2">
              <button id="btn-kuse-copy" type="button" class="kc-btn-primary py-2 text-sm" data-i18n="kuse.copy"
                >Copy prompt</button
              >
              <a
                id="link-kuse"
                href="https://kuse.knsh.com.tw/"
                target="_blank"
                rel="noopener noreferrer"
                class="kc-btn-secondary py-2 text-sm"
                data-i18n="kuse.open"
                >Open 康軒 × Kuse</a
              >
            </div>
            <p id="kuse-copy-status" class="text-xs text-kc-muted"></p>
          </div>
        </div>
      </div>

      <div id="editor-main" class="hidden space-y-4">
        <div class="kc-card space-y-3 p-4 sm:p-5">
          <label class="block text-sm font-semibold text-kc-blue-deep">
            <span data-i18n="editor.subject">Subject / office</span>
            <select id="editor-subject" class="search-input mt-1 py-2 text-sm" required></select>
          </label>
          <p class="text-xs text-kc-muted" data-i18n="editor.subjectHint">
            Required. Keywords become: subject · your display name · auto date
          </p>
          <label class="block text-sm font-semibold text-kc-blue-deep">
            <span data-i18n="editor.filename">Filename</span>
            <span class="mt-1 flex items-center gap-2">
              <input
                id="editor-stem"
                type="text"
                class="search-input flex-1 py-2 text-sm"
                placeholder="fractions-intro"
                maxlength="80"
                autocomplete="off"
              />
              <span class="shrink-0 font-mono text-sm font-bold text-kc-muted">.md</span>
            </span>
          </label>
          <p class="text-xs text-kc-muted" data-i18n="editor.filenameHint">
            Letters (any language), numbers, _ - . — no spaces
          </p>
          <label class="block text-sm font-semibold text-kc-blue-deep">
            <span data-i18n="editor.overview">Overview</span>
            <input
              id="editor-desc"
              type="text"
              class="search-input mt-1 py-2 text-sm"
              data-i18n-placeholder="editor.overviewPlaceholder"
              placeholder="One-line summary (optional)"
              maxlength="160"
            />
          </label>
          <p id="editor-date-hint" class="text-xs font-semibold text-kc-purple"></p>
        </div>

        <div class="editor-shell kc-card overflow-hidden p-0">
          <div class="editor-toolbar" role="toolbar" aria-label="Formatting">
            <button type="button" data-cmd="bold" title="Bold">B</button>
            <button type="button" data-cmd="italic" title="Italic"><em>I</em></button>
            <button type="button" data-cmd="h2" title="Heading">H2</button>
            <button type="button" data-cmd="h3" title="Subheading">H3</button>
            <span class="editor-toolbar-sep" aria-hidden="true"></span>
            <button type="button" data-cmd="ul" title="Bullet list">• List</button>
            <button type="button" data-cmd="ol" title="Numbered list">1. List</button>
            <button type="button" data-cmd="quote" title="Quote">“ ”</button>
            <button type="button" data-cmd="code" title="Inline code">&lt;/&gt;</button>
            <button type="button" data-cmd="codeblock" title="Code block">{ }</button>
          </div>

          <div class="editor-split">
            <div class="editor-pane">
              <div class="editor-pane-label" data-i18n="editor.body">Edit</div>
              <textarea
                id="editor-content"
                class="editor-textarea"
                spellcheck="true"
                placeholder="## Learning goals&#10;&#10;- Point one&#10;- Point two"
              ></textarea>
            </div>
            <div class="editor-pane">
              <div class="editor-pane-label" data-i18n="editor.preview">Preview</div>
              <div id="editor-preview" class="editor-preview"></div>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <button id="editor-save" type="button" class="kc-btn-primary py-2.5 text-sm" data-i18n="editor.save"
            >Save to my Wiki</button
          >
          <button id="editor-download" type="button" class="kc-btn-secondary py-2.5 text-sm" data-i18n="editor.download"
            >Download backup</button
          >
          <p id="editor-status" class="text-sm text-kc-muted"></p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .editor-shell {
    border: 1px solid color-mix(in srgb, var(--kc-line) 80%, white);
  }

  .editor-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    border-bottom: 1px solid color-mix(in srgb, var(--kc-line) 75%, white);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(245, 248, 255, 0.9));
    padding: 0.55rem 0.75rem;
  }

  .editor-toolbar button {
    border-radius: 0.65rem;
    border: 1px solid color-mix(in srgb, var(--kc-line) 70%, white);
    background: white;
    color: var(--kc-blue-deep);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.35rem 0.6rem;
  }

  .editor-toolbar button:hover {
    border-color: color-mix(in srgb, var(--kc-purple) 45%, white);
    background: #f7f4ff;
  }

  .editor-toolbar-sep {
    width: 1px;
    align-self: stretch;
    margin: 0.15rem 0.2rem;
    background: color-mix(in srgb, var(--kc-line) 80%, transparent);
  }

  .editor-split {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .editor-split {
      grid-template-columns: 1fr 1fr;
      min-height: 28rem;
    }
  }

  .editor-pane {
    display: flex;
    min-height: 18rem;
    flex-direction: column;
    border-top: 1px solid color-mix(in srgb, var(--kc-line) 60%, white);
  }

  @media (min-width: 900px) {
    .editor-pane:first-child {
      border-right: 1px solid color-mix(in srgb, var(--kc-line) 60%, white);
    }
  }

  .editor-pane-label {
    background: rgba(255, 255, 255, 0.7);
    color: var(--kc-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 0.4rem 0.85rem;
  }

  .editor-textarea {
    flex: 1;
    width: 100%;
    resize: vertical;
    border: 0;
    background: transparent;
    padding: 0.85rem 1rem 1.2rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--kc-blue-deep);
    outline: none;
    min-height: 16rem;
  }

  .editor-preview {
    flex: 1;
    overflow: auto;
    padding: 0.85rem 1rem 1.2rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--kc-blue-deep);
  }

  .editor-preview :global(h2),
  .editor-preview :global(h3) {
    font-weight: 800;
    margin: 0.9em 0 0.4em;
  }

  .editor-preview :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
  }

  .editor-preview :global(ol) {
    list-style: decimal;
    padding-left: 1.25rem;
  }

  .editor-preview :global(blockquote) {
    border-left: 3px solid color-mix(in srgb, var(--kc-purple) 55%, white);
    padding-left: 0.8rem;
    color: var(--kc-muted);
  }

  .editor-preview :global(code) {
    border-radius: 0.35rem;
    background: #eef2ff;
    padding: 0.1rem 0.35rem;
  }

  .editor-preview :global(pre) {
    overflow: auto;
    border-radius: 0.75rem;
    background: #0f172a;
    color: #e2e8f0;
    padding: 0.85rem 1rem;
  }

  #upload-zone.dragover {
    border-color: var(--kc-purple);
    background: color-mix(in srgb, var(--kc-purple) 8%, white);
  }
</style>

<script>
  import { marked } from 'marked';
  import {
    checkAuthHealth,
    displayUserName,
    fetchMe,
    fetchWikiSubjects,
    listAllWikiFiles,
    listWikiFiles,
    readWikiFile,
    uploadWikiNote,
    isTeacherUser,
  } from '../scripts/auth-client.js';
  import {
    splitFrontmatter,
    buildMarkdownDocument,
    isValidFilenameStem,
    wrapSelection,
    prefixLines,
    formatTaipeiDateLabel,
  } from '../scripts/md-editor.js';

  marked.setOptions({ breaks: true, gfm: true });

  const params = new URLSearchParams(window.location.search);
  const mode = params.get('mode') || 'new'; // new | upload | edit
  const qSubject = params.get('subjectId') || '';
  const qSlug = params.get('slug') || '';

  const gate = document.getElementById('editor-gate');
  const offline = document.getElementById('editor-offline');
  const panel = document.getElementById('editor-panel');
  const editPicker = document.getElementById('edit-picker');
  const uploadZone = document.getElementById('upload-zone');
  const editorMain = document.getElementById('editor-main');
  const fileSelect = document.getElementById('editor-file');
  const subjectSelect = document.getElementById('editor-subject');
  const stemInput = document.getElementById('editor-stem');
  const descInput = document.getElementById('editor-desc');
  const contentArea = document.getElementById('editor-content');
  const previewEl = document.getElementById('editor-preview');
  const statusEl = document.getElementById('editor-status');
  const dateHint = document.getElementById('editor-date-hint');

  let sourceMarkdown = '';
  let defaultSubjectId = 'general';
  let nickname = '';

  function setStatus(text, isError = false) {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.classList.toggle('text-red-600', isError);
    statusEl.classList.toggle('text-kc-muted', !isError);
  }

  function refreshDateHint() {
    if (!dateHint) return;
    const label = formatTaipeiDateLabel();
    dateHint.textContent = `Auto date tag: ${label}`;
  }

  function refreshPreview() {
    if (!previewEl || !contentArea) return;
    previewEl.innerHTML =
      marked.parse(contentArea.value || '', { async: false }) ||
      '<p style="color:var(--kc-muted)">Preview</p>';
  }

  function applyDocToForm(raw, preferredStem = '') {
    sourceMarkdown = raw || '';
    const { data, body } = splitFrontmatter(sourceMarkdown);
    const stem = preferredStem || String(data.title || '').trim() || 'note';
    if (stemInput) stemInput.value = stem.replace(/\.md$/i, '');
    if (descInput) descInput.value = data.description || '';
    if (contentArea) contentArea.value = body || '';
    if (data.subject_id && subjectSelect) {
      subjectSelect.value = data.subject_id;
      defaultSubjectId = data.subject_id;
    }
    refreshPreview();
    refreshDateHint();
  }

  function composeForSave() {
    const stem = stemInput?.value?.trim() || '';
    return buildMarkdownDocument({
      title: stem,
      description: descInput?.value?.trim() || '',
      body: contentArea?.value || '',
      existing: sourceMarkdown,
    });
  }

  function showMainEditor() {
    editorMain?.classList.remove('hidden');
    refreshDateHint();
  }

  function fillSubjects(subjects) {
    if (!subjectSelect) return;
    subjectSelect.innerHTML = '';
    for (const s of subjects) {
      const opt = document.createElement('option');
      opt.value = s.id;
      opt.textContent = s.nameEn && s.nameEn !== s.name ? `${s.name} / ${s.nameEn}` : s.name;
      subjectSelect.appendChild(opt);
    }
    defaultSubjectId = qSubject || subjects[0]?.id || 'general';
    subjectSelect.value = defaultSubjectId;
  }

  async function loadOwnFiles() {
    const subjects = await fetchWikiSubjects();
    fillSubjects(subjects.subjects || []);
    const status = document.getElementById('editor-status');
    const t0 = Date.now();
    let tick = null;
    if (status) {
      status.textContent = 'Loading notes… 0s (cloud sync may take up to ~1 min)';
      tick = setInterval(() => {
        const sec = Math.floor((Date.now() - t0) / 1000);
        status.textContent = `Loading notes… ${sec}s (cloud sync may take up to ~1 min)`;
      }, 1000);
    }
    try {
      const data = await listAllWikiFiles();
      const all = (data.files || []).map((f) => ({
        ...f,
        subjectName: f.subjectName || f.subjectId,
      }));
      if (!fileSelect) return all;
      fileSelect.innerHTML = '<option value="">—</option>';
      for (const f of all) {
        const opt = document.createElement('option');
        opt.value = `${f.subjectId}::${f.slug}`;
        opt.textContent = `${f.subjectName} · ${f.title || f.slug}`;
        fileSelect.appendChild(opt);
      }
      if (status) status.textContent = `${all.length} note(s) ready`;
      return all;
    } finally {
      if (tick) clearInterval(tick);
    }
  }

  function buildKusePrompt(notes) {
    const body = String(notes || '').trim() || '（請在此貼上我的教學筆記內容）';
    return [
      '請幫我把下面的教學筆記整理成一份美觀、結構清楚的 Markdown（.md）檔案。',
      '請使用適當的標題、條列、粗體，並保留重點；不要加入與內容無關的說明。',
      '完成後請輸出完整的 Markdown 內容，方便我下載或複製後上傳到 WikiNB。',
      '',
      '（老師的筆記）',
      '',
      body,
    ].join('\n');
  }

  async function init() {
    const me = await fetchMe().catch(() => ({ authenticated: false }));
    if (!me.authenticated || !isTeacherUser(me.user)) {
      gate?.classList.remove('hidden');
      return;
    }
    nickname = displayUserName(me.user);
    const health = await checkAuthHealth();
    if (!health.online) {
      if (offline) {
        offline.textContent = health.message || 'Auth offline. Run npm run auth.';
        offline.classList.remove('hidden');
      }
      return;
    }
    panel?.classList.remove('hidden');

    const subjects = await fetchWikiSubjects();
    fillSubjects(subjects.subjects || []);

    if (mode === 'edit') {
      editPicker?.classList.remove('hidden');
      await loadOwnFiles();
      if (qSubject && qSlug) {
        if (fileSelect) fileSelect.value = `${qSubject}::${qSlug}`;
        const data = await readWikiFile({ subjectId: qSubject, slug: qSlug });
        defaultSubjectId = qSubject;
        if (subjectSelect) subjectSelect.value = qSubject;
        applyDocToForm(data.content || '', qSlug);
        showMainEditor();
        setStatus(`Loaded: ${qSlug}`);
      }
    } else if (mode === 'upload') {
      uploadZone?.classList.remove('hidden');
    } else {
      showMainEditor();
      if (contentArea) {
        contentArea.value = ['## Learning goals', '', '- ', '', '## Key points', '', '1. '].join('\n');
      }
      refreshPreview();
      setStatus('New draft (not saved yet)');
    }
  }

  subjectSelect?.addEventListener('change', () => {
    defaultSubjectId = subjectSelect.value || 'general';
  });

  fileSelect?.addEventListener('change', async () => {
    const raw = fileSelect.value;
    if (!raw.includes('::')) return;
    const [subjectId, slug] = raw.split('::');
    const data = await readWikiFile({ subjectId, slug });
    defaultSubjectId = subjectId;
    if (subjectSelect) subjectSelect.value = subjectId;
    applyDocToForm(data.content || '', slug);
    showMainEditor();
    setStatus(`Loaded: ${slug}`);
  });

  contentArea?.addEventListener('input', refreshPreview);

  document.querySelectorAll('.editor-toolbar [data-cmd]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cmd = btn.getAttribute('data-cmd');
      if (!contentArea || !cmd) return;
      if (cmd === 'bold') wrapSelection(contentArea, '**', '**', 'bold');
      else if (cmd === 'italic') wrapSelection(contentArea, '*', '*', 'italic');
      else if (cmd === 'h2') prefixLines(contentArea, '## ');
      else if (cmd === 'h3') prefixLines(contentArea, '### ');
      else if (cmd === 'ul') prefixLines(contentArea, '- ');
      else if (cmd === 'ol') prefixLines(contentArea, '1. ');
      else if (cmd === 'quote') prefixLines(contentArea, '> ');
      else if (cmd === 'code') wrapSelection(contentArea, '`', '`', 'code');
      else if (cmd === 'codeblock') wrapSelection(contentArea, '```\n', '\n```', 'code');
      refreshPreview();
    });
  });

  document.getElementById('editor-save')?.addEventListener('click', async () => {
    const stem = stemInput?.value?.trim() || '';
    const subjectId = subjectSelect?.value || defaultSubjectId;
    if (!subjectId) {
      setStatus('Please choose a subject / office', true);
      subjectSelect?.focus();
      return;
    }
    if (!isValidFilenameStem(stem)) {
      setStatus('Invalid filename: letters/numbers/_-./ only, no spaces', true);
      stemInput?.focus();
      return;
    }
    if (!(contentArea?.value || '').trim()) {
      setStatus('Please write some content', true);
      return;
    }
    const filename = `${stem}.md`;
    const content = composeForSave();
    const btn = document.getElementById('editor-save');
    try {
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = 'Saving…';
      }
      const result = await uploadWikiNote({
        filename,
        content,
        subjectId,
      });
      sourceMarkdown = content;
      defaultSubjectId = subjectId;
      setStatus(result.message || 'Saved');
      refreshDateHint();
    } catch (err) {
      setStatus(err.message || 'Save failed', true);
    } finally {
      if (btn) {
        btn.removeAttribute('disabled');
        btn.textContent = 'Save to my Wiki';
      }
    }
  });

  document.getElementById('editor-download')?.addEventListener('click', () => {
    const stem = stemInput?.value?.trim() || 'note';
    const content = composeForSave();
    const blob = new Blob([content], { type: 'text/markdown;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${stem}.md`;
    a.click();
    URL.revokeObjectURL(url);
    setStatus(`Downloaded ${a.download}`);
  });

  async function openImportedFile(file) {
    if (!file) return;
    const text = await file.text();
    const stem = String(file.name || 'note').replace(/\.md$/i, '');
    applyDocToForm(text, stem);
    uploadZone?.classList.add('hidden');
    showMainEditor();
    setStatus(`Imported: ${file.name} — choose subject, then save`);
  }

  document.getElementById('editor-upload')?.addEventListener('change', async (e) => {
    const input = e.target;
    const file = input.files?.[0];
    input.value = '';
    await openImportedFile(file);
  });

  ;['dragenter', 'dragover'].forEach((evt) => {
    uploadZone?.addEventListener(evt, (e) => {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });
  });
  ;['dragleave', 'drop'].forEach((evt) => {
    uploadZone?.addEventListener(evt, (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
    });
  });
  uploadZone?.addEventListener('drop', async (e) => {
    const file = e.dataTransfer?.files?.[0];
    if (file) await openImportedFile(file);
  });

  document.getElementById('btn-kuse-toggle')?.addEventListener('click', () => {
    document.getElementById('kuse-panel')?.classList.toggle('hidden');
  });

  document.getElementById('btn-kuse-copy')?.addEventListener('click', async () => {
    const notes = document.getElementById('kuse-notes')?.value || '';
    const prompt = buildKusePrompt(notes);
    const status = document.getElementById('kuse-copy-status');
    try {
      await navigator.clipboard.writeText(prompt);
      if (status) status.textContent = 'Copied. Open 康軒 × Kuse and paste the prompt.';
    } catch {
      if (status) status.textContent = 'Copy failed — select and copy manually.';
    }
  });

  init();
</script>
