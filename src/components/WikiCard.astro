---
/**
 * 筆記卡片 — 日期 → keywords（老師固定／科目隨介面語言）→ 標題 → 摘要
 */
interface Props {
  slug: string;
  title: string;
  description: string;
  teacher: string;
  subject: string;
  subjectEn?: string;
  date: string;
}

const { slug, title, description, teacher, subject, subjectEn, date } = Astro.props;
const base = import.meta.env.BASE_URL;
const subjectLabelEn = subjectEn || subject;
---

<a href={`${base}wiki/${slug}`} class="kc-card-hover flex h-full flex-col p-5 md:p-6">
  <div class="mb-2 flex min-h-[1.25rem] items-center">
    <time class="text-xs font-semibold text-kc-purple">{date}</time>
  </div>

  <div class="mb-2 flex min-h-[1.5rem] flex-wrap gap-2">
    {teacher ? (
      <span class="tag-keyword">{teacher}</span>
    ) : (
      <span class="tag-badge invisible select-none" aria-hidden="true">占位</span>
    )}
    {subject ? (
      <span class="tag-keyword" data-locale-text data-zh={subject} data-en={subjectLabelEn}>
        {subject}
      </span>
    ) : (
      <span class="tag-badge invisible select-none" aria-hidden="true">占位</span>
    )}
  </div>

  <h3 class="line-clamp-1 font-display text-lg font-bold text-kc-blue-deep md:text-xl">{title}</h3>
  <p class="mt-2 line-clamp-2 flex-1 text-sm leading-relaxed text-kc-muted">{description}</p>
</a>
