---
import sites from '../../config/sites.json';

const base = import.meta.env.BASE_URL;
const navUrl = sites.sites.navigator.url;
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/40 bg-white/45 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-2 px-3 py-3 md:px-8">
    <a
      href={base}
      class="group flex min-w-0 items-center gap-2.5 rounded-full py-1 pr-2 transition hover:bg-white/50 sm:gap-3 sm:pr-3"
      data-i18n-aria="nav.homeTitle"
      data-i18n-title="nav.homeTitle"
      aria-label="Back to main"
      title="Back to main"
    >
      <img
        src={`${base}brand/kangchiao-logo.png`}
        alt=""
        class="h-7 w-auto transition-opacity group-hover:opacity-90 sm:h-8"
        width="154"
        height="28"
      />
      <span class="hidden h-5 w-px bg-[color:var(--kc-line)] sm:block" aria-hidden="true"></span>
      <span
        class="home-chip hidden rounded-full px-3 py-1 text-xs font-bold text-white transition group-hover:scale-105 sm:inline-flex"
        data-i18n="nav.home"
      >
        Main
      </span>
    </a>

    <nav class="flex max-w-[75%] flex-wrap items-center justify-end gap-1 md:max-w-none md:gap-2">
      <a href={`${base}search`} class="nav-wikinb" data-i18n="nav.wikinb">WikiNB</a>
      <a
        id="nav-ai"
        href={navUrl}
        class="nav-secondary"
        target="_blank"
        rel="noopener noreferrer"
        data-i18n="nav.ai"
      >
        AI Tools
      </a>
      <a
        id="nav-add-note"
        href={`${base}notes`}
        class="nav-addnote"
        hidden
        aria-hidden="true"
        tabindex="-1"
      >
        <span class="nav-addnote-label" data-i18n="home.addNote">+ Add note</span>
      </a>
      <button id="btn-lang" type="button" class="nav-lang" title="切換為繁體中文">中文</button>
      <div id="nav-user-wrap" class="relative hidden">
        <button
          id="nav-user"
          type="button"
          class="nav-user max-w-[12rem] truncate text-xs font-semibold text-kc-blue-deep sm:max-w-[16rem] sm:text-sm"
          aria-haspopup="menu"
          aria-expanded="false"
        ></button>
        <div
          id="nav-user-menu"
          class="nav-user-menu absolute right-0 top-[calc(100%+0.4rem)] z-[90] hidden min-w-[11rem] overflow-hidden rounded-xl border border-white/70 bg-white/95 py-1 shadow-lg backdrop-blur-md"
          role="menu"
        >
          <a
            id="nav-edit-nick"
            href={`${base}nickname`}
            class="nav-user-item"
            role="menuitem"
            data-i18n="login.editNickname"
            >Edit display name</a
          >
          <button id="nav-logout" type="button" class="nav-user-item w-full text-left" role="menuitem" data-i18n="login.logout"
            >Log out</button
          >
        </div>
      </div>
      <a id="nav-login" href={`${base}login`} class="nav-link" data-i18n="nav.login">Log in</a>
    </nav>
  </div>
</header>

<script>
  import { mountI18n } from '../scripts/i18n.js';
  import { mountNavAuth } from '../scripts/auth-client.js';
  mountI18n();
  mountNavAuth();
</script>

<style>
  /* 登入鍵：維持原樣，勿動 display（避免蓋掉 .hidden） */
  .nav-link {
    @apply items-center rounded-full px-3 py-2 text-sm font-semibold text-kc-blue-deep transition-colors hover:bg-white/70 sm:px-4;
    display: inline-flex;
  }

  .nav-link.hidden {
    display: none !important;
  }

  /* 只統一 WikiNB／AI／新增筆記／語言：字級與內距（不用 display） */
  .nav-wikinb,
  .nav-secondary,
  .nav-addnote,
  .nav-lang {
    box-sizing: border-box;
    min-height: 2.25rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    line-height: 1.25;
    font-weight: 700;
  }

  @media (min-width: 640px) {
    .nav-wikinb,
    .nav-secondary,
    .nav-addnote,
    .nav-lang {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }

  .nav-wikinb {
    @apply inline-flex items-center rounded-full text-white transition hover:opacity-95;
    background: linear-gradient(120deg, var(--kc-blue), var(--kc-purple));
    box-shadow: 0 6px 18px rgba(27, 79, 156, 0.28);
  }

  .nav-secondary {
    @apply inline-flex items-center rounded-full text-white transition hover:opacity-95;
    background: linear-gradient(120deg, var(--kc-blue-soft), #3d9bb8);
    box-shadow: 0 6px 18px rgba(61, 155, 184, 0.3);
  }

  .nav-secondary.hidden {
    display: none !important;
  }

  /* 新增筆記：顯示邏輯不變，僅尺寸跟上面對齊 */
  .nav-addnote {
    position: relative;
    isolation: isolate;
    display: none;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid transparent;
    text-decoration: none;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(120deg, #4285f4, #9b72cb, #d96570, #fbbc05, #34a853, #4285f4) border-box;
    box-shadow: 0 8px 22px rgba(66, 133, 244, 0.12);
    transition: box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .nav-addnote.is-teacher-visible {
    display: inline-flex;
  }

  .nav-addnote::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      rgba(66, 133, 244, 0.08),
      rgba(155, 114, 203, 0.1),
      rgba(217, 101, 112, 0.08),
      rgba(251, 188, 5, 0.08),
      rgba(52, 168, 83, 0.08)
    );
    opacity: 0.85;
  }

  .nav-addnote-label {
    position: relative;
    z-index: 2;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: 0.02em;
    white-space: nowrap;
    background: linear-gradient(105deg, #1a73e8 0%, #7b61ff 45%, #d96570 75%, #0f9d9a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nav-addnote:hover,
  .nav-addnote:focus-visible {
    box-shadow: 0 10px 24px rgba(123, 97, 255, 0.18);
    outline: none;
  }

  .nav-lang {
    @apply inline-flex items-center justify-center rounded-full border text-kc-blue-deep transition hover:bg-white;
    border-color: var(--kc-line);
    background: rgba(255, 255, 255, 0.75);
    min-width: 3rem;
    cursor: pointer;
    font-family: inherit;
  }

  .nav-lang:hover {
    border-color: rgba(107, 61, 154, 0.35);
  }

  .nav-user {
    @apply cursor-pointer rounded-full bg-white/60 px-2.5 py-1.5 transition hover:bg-white;
  }

  .nav-user-item {
    display: block;
    padding: 0.55rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--kc-blue-deep);
    text-decoration: none;
    background: transparent;
    border: 0;
    font-family: inherit;
    cursor: pointer;
  }

  .nav-user-item:hover {
    background: color-mix(in srgb, var(--kc-mist) 70%, white);
  }

  .home-chip {
    background: linear-gradient(120deg, var(--kc-blue), var(--kc-purple));
    box-shadow: 0 6px 16px rgba(27, 79, 156, 0.28);
  }
</style>
