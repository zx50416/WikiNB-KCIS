---
interface Props {
  placeholder?: string;
  size?: 'sm' | 'lg';
  action?: string;
  showButton?: boolean;
  buttonLabel?: string;
}

const {
  size = 'sm',
  action = '/search',
  showButton = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const formAction = action.startsWith('http') ? action : `${base}${action.replace(/^\//, '')}`;
---

<form action={formAction} method="get" class="w-full">
  <div class="relative w-full">
    <span
      class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-kc-blue-soft"
      aria-hidden="true"
    >
      🔍
    </span>
    <input
      type="search"
      name="q"
      placeholder="輸入關鍵字，例如：陳老師、數學、分數…"
      data-i18n-placeholder="search.placeholder"
      class:list={['search-input', size === 'lg' && 'py-4 text-lg']}
      autocomplete="off"
    />
  </div>
  {showButton && (
    <button
      type="submit"
      class="kc-btn-primary mt-4 w-full justify-center py-3 text-base md:text-lg"
      data-i18n="search.button"
    >
      Search
    </button>
  )}
</form>
