---
/**
 * Add note hub (header CTA)
 * - Text editor / Upload .md (+ Kuse helper)
 * - Edit/delete live under My notes
 */
const base = import.meta.env.BASE_URL;
---

<div class="home-search w-full" data-dual="true">
  <form action={`${base}search`} method="get" class="w-full">
    <div class="relative w-full">
      <span
        class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-kc-blue-soft"
        aria-hidden="true"
      >
        🔍
      </span>
      <input
        type="search"
        name="q"
        placeholder="Search by teacher, subject, or keyword…"
        data-i18n-placeholder="home.placeholder"
        class="search-input py-3 text-base sm:py-4 sm:text-lg"
        autocomplete="off"
      />
    </div>

    <div id="search-actions-guest" class="mt-4 grid grid-cols-2 gap-3">
      <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
        Search
      </button>
      <a
        href={`${base}teachers`}
        class="kc-btn-secondary justify-center py-3 text-sm sm:text-base"
        data-i18n="home.teachers"
      >
        Teachers
      </a>
    </div>

    <div id="search-actions-student" class="mt-4 hidden space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
          Search
        </button>
        <a href={`${base}teachers`} class="kc-btn-secondary justify-center py-3 text-sm sm:text-base" data-i18n="home.teachers">
          Teachers
        </a>
      </div>
      <a href={`${base}codex`} class="home-btn-gemini justify-center py-3 text-sm sm:text-base"
        ><span class="home-btn-gemini-label" data-i18n="nav.gemini">Gemini × KCIS</span></a
      >
    </div>

    <div id="search-actions-teacher" class="mt-4 hidden space-y-3">
      <a href={`${base}my-notes`} class="home-btn-mynotes">
        <span class="home-btn-mynotes-label" data-i18n="home.myNotes">My notes</span>
      </a>
      <div class="grid grid-cols-2 gap-3">
        <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
          Search
        </button>
        <a href={`${base}codex`} class="home-btn-gemini justify-center py-3 text-sm sm:text-base"
          ><span class="home-btn-gemini-label" data-i18n="nav.gemini">Gemini × KCIS</span></a
        >
      </div>
    </div>
  </form>
</div>

<script>
  document.addEventListener('wikinb:auth-change', (ev) => {
    const { loggedIn, isTeacher } = ev.detail || {};
    document.getElementById('search-actions-guest')?.classList.toggle('hidden', loggedIn);
    document.getElementById('search-actions-student')?.classList.toggle('hidden', !loggedIn || isTeacher);
    document.getElementById('search-actions-teacher')?.classList.toggle('hidden', !loggedIn || !isTeacher);
  });

  import('../scripts/auth-client.js').then(({ fetchMe, isTeacherUser }) => {
    fetchMe()
      .then((me) => {
        const loggedIn = Boolean(me.authenticated && me.user);
        document.dispatchEvent(
          new CustomEvent('wikinb:auth-change', {
            detail: { loggedIn, user: me.user, isTeacher: loggedIn && isTeacherUser(me.user) },
          }),
        );
      })
      .catch(() => {});
  });
</script>

<style>
  .home-btn-gemini {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid transparent;
    padding: 0.65rem 1.5rem;
    font-family: inherit;
    font-weight: 700;
    color: #1a73e8;
    text-decoration: none;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(120deg, #4285f4, #9b72cb, #d96570, #fbbc05, #34a853, #4285f4) border-box;
    box-shadow: 0 8px 22px rgba(66, 133, 244, 0.12);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .home-btn-gemini-label {
    position: relative;
    z-index: 2;
    letter-spacing: 0.02em;
    background: linear-gradient(105deg, #1a73e8 0%, #7b61ff 45%, #d96570 75%, #0f9d9a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .home-btn-gemini::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      rgba(66, 133, 244, 0.08),
      rgba(155, 114, 203, 0.1),
      rgba(217, 101, 112, 0.08),
      rgba(251, 188, 5, 0.08),
      rgba(52, 168, 83, 0.08)
    );
    opacity: 0.85;
  }

  .home-btn-gemini:hover,
  .home-btn-gemini:focus-visible {
    transform: translateY(-1px) scale(1.015);
    box-shadow: 0 12px 28px rgba(123, 97, 255, 0.2);
    outline: none;
  }

  .home-btn-mynotes {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    padding: 0.85rem 1.5rem;
    text-decoration: none;
    background: linear-gradient(120deg, var(--kc-blue-soft), #3d9bb8 45%, var(--kc-purple));
    background-size: 200% 200%;
    box-shadow: 0 12px 32px rgba(27, 79, 156, 0.2);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    animation: mynotes-shift 5s ease infinite;
  }

  .home-btn-mynotes-label {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #fff;
  }

  .home-btn-mynotes:hover,
  .home-btn-mynotes:focus-visible {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 16px 40px rgba(61, 155, 184, 0.3);
    outline: none;
  }

  @keyframes mynotes-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>
