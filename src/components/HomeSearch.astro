---
/**
 * Add note hub (header CTA)
 * - Text editor / Upload .md (+ Kuse helper)
 * - Edit/delete live under My notes
 */
const base = import.meta.env.BASE_URL;
---

<div class="home-search w-full" data-dual="true">
  <form action={`${base}search`} method="get" class="w-full">
    <div class="relative w-full">
      <span
        class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-kc-blue-soft"
        aria-hidden="true"
      >
        🔍
      </span>
      <input
        type="search"
        name="q"
        placeholder="Search by teacher, subject, or keyword…"
        data-i18n-placeholder="home.placeholder"
        class="search-input py-3 text-base sm:py-4 sm:text-lg"
        autocomplete="off"
      />
    </div>

    <div id="search-actions-guest" class="mt-4 grid grid-cols-2 gap-3">
      <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
        Search
      </button>
      <a
        href={`${base}teachers`}
        class="kc-btn-secondary justify-center py-3 text-sm sm:text-base"
        data-i18n="home.teachers"
      >
        Teachers
      </a>
    </div>

    <div id="search-actions-student" class="mt-4 hidden space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
          Search
        </button>
        <a href={`${base}teachers`} class="kc-btn-secondary justify-center py-3 text-sm sm:text-base" data-i18n="home.teachers">
          Teachers
        </a>
      </div>
      <a href={`${base}codex`} class="home-btn-gemini justify-center py-3 text-sm sm:text-base"
        ><span class="home-btn-gemini-label" data-i18n="nav.gemini">Gemini × KCIS</span></a
      >
    </div>

    <div id="search-actions-teacher" class="mt-4 hidden space-y-3">
      <a href={`${base}notes`} class="home-btn-addnote" aria-label="+ Add note">
        <span class="home-btn-addnote-shine" aria-hidden="true"></span>
        <span class="home-btn-addnote-label" data-i18n="home.addNote">+ Add note</span>
      </a>
      <div class="grid grid-cols-2 gap-3">
        <button type="submit" class="kc-btn-primary justify-center py-3 text-sm sm:text-base" data-i18n="home.search">
          Search
        </button>
        <a href={`${base}codex`} class="home-btn-gemini justify-center py-3 text-sm sm:text-base"
          ><span class="home-btn-gemini-label" data-i18n="nav.gemini">Gemini × KCIS</span></a
        >
      </div>
    </div>
  </form>
</div>

<script>
  document.addEventListener('wikinb:auth-change', (ev) => {
    const { loggedIn, isTeacher } = ev.detail || {};
    document.getElementById('search-actions-guest')?.classList.toggle('hidden', loggedIn);
    document.getElementById('search-actions-student')?.classList.toggle('hidden', !loggedIn || isTeacher);
    document.getElementById('search-actions-teacher')?.classList.toggle('hidden', !loggedIn || !isTeacher);
  });

  import('../scripts/auth-client.js').then(({ fetchMe, isTeacherUser }) => {
    fetchMe()
      .then((me) => {
        const loggedIn = Boolean(me.authenticated && me.user);
        document.dispatchEvent(
          new CustomEvent('wikinb:auth-change', {
            detail: { loggedIn, user: me.user, isTeacher: loggedIn && isTeacherUser(me.user) },
          }),
        );
      })
      .catch(() => {});
  });
</script>

<style>
  .home-btn-gemini {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid transparent;
    padding: 0.65rem 1.5rem;
    font-family: inherit;
    font-weight: 700;
    color: #1a73e8;
    text-decoration: none;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(120deg, #4285f4, #9b72cb, #d96570, #fbbc05, #34a853, #4285f4) border-box;
    box-shadow: 0 8px 22px rgba(66, 133, 244, 0.12);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .home-btn-gemini-label {
    position: relative;
    z-index: 2;
    letter-spacing: 0.02em;
    background: linear-gradient(105deg, #1a73e8 0%, #7b61ff 45%, #d96570 75%, #0f9d9a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .home-btn-gemini::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    background: linear-gradient(
      120deg,
      rgba(66, 133, 244, 0.08),
      rgba(155, 114, 203, 0.1),
      rgba(217, 101, 112, 0.08),
      rgba(251, 188, 5, 0.08),
      rgba(52, 168, 83, 0.08)
    );
    opacity: 0.85;
  }

  .home-btn-gemini:hover,
  .home-btn-gemini:focus-visible {
    transform: translateY(-1px) scale(1.015);
    box-shadow: 0 12px 28px rgba(123, 97, 255, 0.2);
    outline: none;
  }

  /* 老師首頁主 CTA：康橋藍→紫實心＋掃光＋呼吸光暈（要比下方按鈕更醒目） */
  .home-btn-addnote {
    position: relative;
    isolation: isolate;
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 9999px;
    padding: 0.95rem 1.5rem;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(
      115deg,
      var(--kc-blue) 0%,
      var(--kc-blue-soft) 38%,
      var(--kc-purple) 100%
    );
    background-size: 180% 180%;
    box-shadow:
      0 10px 28px rgba(27, 79, 156, 0.28),
      0 0 0 0 rgba(107, 61, 154, 0.35);
    animation:
      addnote-shift 4.5s ease-in-out infinite,
      addnote-glow 2.4s ease-in-out infinite;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .home-btn-addnote-shine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -40%;
    width: 38%;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(255, 255, 255, 0.15) 40%,
      rgba(255, 255, 255, 0.55) 50%,
      rgba(255, 255, 255, 0.15) 60%,
      transparent 100%
    );
    transform: skewX(-18deg);
    animation: addnote-shine 2.8s ease-in-out infinite;
  }

  .home-btn-addnote-label {
    position: relative;
    z-index: 2;
    font-size: 1.12rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    color: #fff;
    text-shadow: 0 1px 2px rgba(14, 47, 102, 0.25);
  }

  .home-btn-addnote:hover,
  .home-btn-addnote:focus-visible {
    transform: translateY(-2px) scale(1.025);
    box-shadow:
      0 16px 40px rgba(27, 79, 156, 0.35),
      0 0 0 4px rgba(143, 107, 184, 0.22);
    outline: none;
    animation-play-state: paused;
  }

  .home-btn-addnote:hover .home-btn-addnote-shine,
  .home-btn-addnote:focus-visible .home-btn-addnote-shine {
    animation-play-state: paused;
  }

  @keyframes addnote-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes addnote-glow {
    0%,
    100% {
      box-shadow:
        0 10px 28px rgba(27, 79, 156, 0.28),
        0 0 0 0 rgba(107, 61, 154, 0.28);
    }
    50% {
      box-shadow:
        0 14px 36px rgba(107, 61, 154, 0.38),
        0 0 0 6px rgba(79, 126, 200, 0.18);
    }
  }

  @keyframes addnote-shine {
    0% {
      left: -45%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    55% {
      left: 110%;
      opacity: 1;
    }
    56%,
    100% {
      left: 110%;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-btn-addnote,
    .home-btn-addnote-shine {
      animation: none;
    }
  }
</style>
