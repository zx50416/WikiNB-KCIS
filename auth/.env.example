# Auth / API — 複製為 auth/.env（勿 commit）

PORT=8788
AUTH_BASE_URL=http://127.0.0.1:8788
FRONTEND_ORIGIN=http://127.0.0.1:4321
# 多個前端來源用逗號分隔（部署 GitHub Pages 後加上）
# FRONTEND_ORIGINS=https://zx50416.github.io
FRONTEND_BASE_PATH=/WikiNB-KCIS/
PROJECT_ROOT=

# Session（請改成長隨機字）
SESSION_SECRET=change-me-to-a-long-random-string

# 用 kainnne@kcis.com.tw 的「應用程式密碼」代寄驗證碼
# Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼
# Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼
DEV_LOG_CODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kainnne@kcis.com.tw
SMTP_PASS=請換成你的應用程式密碼
SMTP_FROM=WikiNB KCIS <kainnne@kcis.com.tw>
# Pages 前端打本機 Auth 時開啟
# FRONTEND_ORIGINS=https://zx50416.github.io
# COOKIE_SAMESITE=none

# LLM：codex（預設）| 之後可換 openai / custom
LLM_PROVIDER=codex
# LLM_MODEL=
# LLM_BASE_URL=
