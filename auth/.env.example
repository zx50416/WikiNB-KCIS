# Auth / API — 複製為 auth/.env（勿 commit）

PORT=8788
HOST=127.0.0.1
AUTH_BASE_URL=http://127.0.0.1:8788
FRONTEND_ORIGIN=http://127.0.0.1:4321
# 線上 Pages 來源（主機模式必填）
FRONTEND_ORIGINS=https://zx50416.github.io
FRONTEND_BASE_PATH=/WikiNB-KCIS/
PROJECT_ROOT=

# Session（請改成長隨機字）
SESSION_SECRET=change-me-to-a-long-random-string

# --- 主機模式（Mac／Windows + Cloudflare Tunnel）---
# Tunnel 取得 https://xxxx 後：
# AUTH_BASE_URL=https://xxxx.trycloudflare.com
# COOKIE_SAMESITE=none
# 並把同一網址寫入 config/sites.json → auth.productionUrl，再 git push

# 用 kainnne@kcis.com.tw 的「應用程式密碼」代寄驗證碼
DEV_LOG_CODE=true
# DEV_LOG_CODE=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=kainnne@kcis.com.tw
# SMTP_PASS=請換成你的應用程式密碼
# SMTP_FROM=WikiNB KCIS <kainnne@kcis.com.tw>

# LLM：codex（預設）— 使用「這台主機」上的 Codex CLI
LLM_PROVIDER=codex
# LLM_MODEL=
# LLM_BASE_URL=
